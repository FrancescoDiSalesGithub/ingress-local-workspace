;
; BIND reverse data file for "this host on this network" zone
;
$TTL    604800
@       IN      SOA     yournet.net. admin.yournet.net. (
                              71       ; Serial
                         604800         ; Refresh
                          86400         ; Retry
                        2419200         ; Expire
                         604800 )       ; Negative Cache TTL
;
@       IN      NS      yournet.net.
@       IN      A       192.168.x.x
kube-cluster    IN      A       192.168.x.x
